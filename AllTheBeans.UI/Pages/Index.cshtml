@page
@model AllTheBeans.UI.Pages.IndexModel
@{
    ViewData["Title"]  =  "Coffee Beans";
}

<link rel = "stylesheet" href = "/css/site.css" />

<div>
    <h1 class = "h1" style = "display: flex; justify-content: center;">Coffee beans</h1>

    <nav aria-label = "Primary" style = "display: block; width: 100%; margin: 16px 0; padding: 8px 0; clear: both;">
        <a href = "/" style  =  "display: inline-block; margin-right: 16px;">Beans</a>
        <a href = "/BeanOfTheDay" style = "display: inline-block; margin-right: 16px;">Bean of the Day</a>
        <a href = "/Order" style = "display: inline-block;">Order</a>
    </nav>
</div>

<section class = "card p-16">
    <form method = "get" class = "filters" role = "search" aria-label = "Search beans">
        <div class = "field">
            <label asp-for = "Query">Search</label>
            <input asp-for = "Query" name = "query" placeholder = "Query search" />
        </div>

        <div class = "field">
            <label asp-for = "Colour">Colour</label>
            <select asp-for = "Colour" name = "colour">
                <option value = "">Any</option>
                @foreach (var c in Model.AvailableColours)
                {
                    bool isPicked = (c == Model.Colour);

                    if (isPicked)
                    {
                        <option value="@c" selected>@c</option>
                    }
                    else
                    {
                        <option value="@c">@c</option>
                    }
                }
            </select>
        </div>

        <div class = "actions">
            <button class = "btn" type = "submit">Filter</button>
            <a class = "btn btn-ghost" href = "/">Reset</a>
        </div>
    </form>
</section>

<section class = "grid mt-16" aria-label = "Bean list">
    @foreach (var bean in Model.Beans)
    {
        <article class = "bean-tile" aria-label = "Bean">
            <a href = "/Bean?beanId=@bean._id" class = "bean-link">
                <div class = "bean-image" style  =  "max-height: 500px; max-width: 500px;">
                    @if (!string.IsNullOrWhiteSpace(bean.Image))
                    {
                    <img src = "@bean.Image" alt = "Photo of @bean.Name" loading = "lazy" style = "max-width: 500px; max-height: 500px;object-fit:cover;" />

                    }
                    else
                    {
                        <div class = "image-placeholder" aria-hidden = "true"></div>
                    }
                </div>

                <div class = "bean-body">
                    <h2 class = "h2">@bean.Name</h2>
                    <div class = "meta">
                        <span>@bean.Colour</span>
                        <span>@bean.Country</span>
                        @if (!string.IsNullOrWhiteSpace(bean.Cost))
                        {
                            <span>@bean.Cost</span>
                        }
                    </div>

                    <p>@bean.Description</p>

                    @if (bean.IsBotD)
                    {
                        <span>Bean of the day</span>
                    }
                </div>
            </a>
        </article>
    }
</section>

